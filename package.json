{
  "name": "legal-transcribe-app",
  "private": true,
  "version": "0.0.1",
  "packageManager": "pnpm@10.28.0",
  "engines": {
    "node": ">=20",
    "pnpm": ">=8"
  },
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "lint": "eslint --ext .ts,.tsx apps/web/src apps/api/src packages/shared-types/src",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "build:web": "pnpm --filter @transcribe/shared-types build && pnpm --filter @transcribe/web build",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md}\" --ignore-path .gitignore"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "prettier": "^3.2.5",
    "typescript": "^5.4.5"
  }
}
